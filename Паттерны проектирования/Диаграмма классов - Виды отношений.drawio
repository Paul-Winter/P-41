        <mxCell id="bZYXF4KpNWjfESPcemhR-43" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="отношение ассоциации" vertex="1">
